# Rate limiting
# LLM_RPM_LIMIT=38

# Queue & workers
# LLM_QUEUE_MAX=100
# LLM_WORKERS=2
# LLM_STREAM_CONCURRENCY=20

# Cooldown (seconds)
# LLM_COOLDOWN_TIMEOUT=10
# LLM_COOLDOWN_ERROR=15

# Logging
# LLM_LOG_DIR=logs
