# LLM backend configuration
# Add as many backends as you need: BACKEND_1_URL/KEY, BACKEND_2_URL/KEY, …
#
# URL      — OpenAI-compatible chat completions endpoint
# KEY      — API key (will be sent as "Bearer <key>")
# MODEL    — (optional) route this model name exclusively to this backend
# PROXY    — (optional) route this backend through a proxy: http://, https://, or socks5://
#
# Model resolution: BACKEND_N_MODEL > BASE_MODEL > request model

# BASE_MODEL — (optional) default model sent to backends that don't specify BACKEND_N_MODEL
# BASE_MODEL=gpt-4o-mini

BACKEND_1_URL=https://api.openai.com/v1/chat/completions
BACKEND_1_KEY=sk-your-key-here
# BACKEND_1_MODEL=gpt-4o
# BACKEND_1_PROXY=socks5://user:pass@127.0.0.1:1080

# BACKEND_2_URL=https://api.anthropic.com/v1/messages
# BACKEND_2_KEY=sk-ant-another-key-here
# BACKEND_2_MODEL=claude-3-opus
# BACKEND_2_PROXY=http://proxy.example.com:8080

# Gateway tuning (optional, defaults shown)
# LLM_RPM_LIMIT=38
# LLM_QUEUE_MAX=100
# LLM_WORKERS=2
# LLM_STREAM_CONCURRENCY=20

# Request limits
# LLM_MAX_REQUEST_BYTES=1048576
# LLM_REQUEST_TIMEOUT=120

# CORS (comma-separated origins, * for all)
# LLM_CORS_ORIGINS=*

# Logging
# LLM_LOG_DIR=logs
